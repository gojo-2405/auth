# ─────────────────────────────────────────────
#  TechSite – Environment Variables
# ─────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# JWT Secret (change in production – use a long random string)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ─── PostgreSQL / AWS RDS ────────────────────
# Local development
DB_HOST=localhost
DB_PORT=5432
DB_NAME=techsite_db
DB_USER=postgres
DB_PASSWORD=your_password

# For AWS RDS, replace with your RDS endpoint:
# DB_HOST=your-rds-instance.xxxxxxxx.us-east-1.rds.amazonaws.com
# DB_PORT=5432
# DB_NAME=techsite_db
# DB_USER=postgres
# DB_PASSWORD=your_rds_password
# DB_SSL=true          # set to true for RDS

# CORS – allowed origin for the frontend
CLIENT_URL=http://localhost:5173
