{
    "family": "nex-server",
    "taskRoleArn": "arn:aws:iam::463367046625:role/ecsTaskExecutionRole-ssm",
    "containerDefinitions": [
      {
        "name": "nex-server",
        "image": "463367046625.dkr.ecr.eu-north-1.amazonaws.com/earth:GIT_COMMIT",
        "cpu": 300,
        "memory": 300,
        "memoryReservation": 200,
        "volumesFrom": [],
        "portMappings": [
          {
            "hostPort": 0,
            "containerPort": 5000,
            "protocol": "tcp"
          }
        ],
        "environment": [
        { "name": "NODE_ENV",       "value": "production" },
        { "name": "PORT",           "value": "5000" },
        { "name": "DB_HOST",        "value": "test.c94sysqc07m0.eu-north-1.rds.amazonaws.com" },
        { "name": "DB_PORT",        "value": "5432" },
        { "name": "DB_NAME",        "value": "techsite_db" },
        { "name": "DB_USER",        "value": "postgres" },
        { "name": "DB_PASSWORD",    "value": "admin123" },
        { "name": "DB_SSL",         "value": "true" },
        { "name": "JWT_SECRET",     "value": "EsIenVpBiHjarLhzrnq712ronsmoDY1w" },
        { "name": "JWT_EXPIRES_IN", "value": "7d" },
        { "name": "CLIENT_URL",     "value": "http://localhost" }
      ],
        "logConfiguration": {
          "logDriver": "awslogs",
          "options": {
            "awslogs-group": "ecs/server",
            "awslogs-region": "eu-north-1",
            "awslogs-stream-prefix": "nex-server"
          }
        },
        "essential": true,
        "mountPoints": []
      }
    ]
  }
  
